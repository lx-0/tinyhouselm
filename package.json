{
  "name": "tina",
  "private": true,
  "version": "0.0.0",
  "description": "Live simulation of hundreds of AI personas with a pixelated UI.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @tina/sim dev",
    "hello": "pnpm --filter @tina/sim hello",
    "sim": "pnpm --filter @tina/sim sim",
    "gen-personas": "pnpm --filter @tina/sim gen-personas",
    "profile": "pnpm --filter @tina/sim profile",
    "web": "pnpm --filter @tina/web web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
